{
  "name": "@aljendro/cli",
  "version": "1.0.0",
  "description": "A CLI tool built with ClojureScript and shadow-cljs",
  "bin": {
    "t": "./bin/t"
  },
  "scripts": {
    "build": "shadow-cljs compile cli && chmod +x bin/t",
    "watch": "shadow-cljs watch cli",
    "release": "shadow-cljs release cli && chmod +x bin/t"
  },
  "devDependencies": {
    "shadow-cljs": "^2.28.18"
  },
  "dependencies": {
    "@aws-sdk/client-sts": "^3.940.0",
    "@inquirer/prompts": "^7.10.1",
    "@smithy/shared-ini-file-loader": "^4.4.0",
    "handlebars": "^4.7.8",
    "ink": "^6.8.0",
    "nbb": "^1.4.206",
    "react": "^19.2.4"
  }
}
