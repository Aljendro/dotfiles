(def pulse-colors
  ["#004400" "#006600" "#008800" "#00aa00" "#00cc00" "#00ff00"
   "#00cc00" "#00aa00" "#008800" "#006600"])

(def bar-width 40)

(defn Splash [rows cols on-done]
  (r/with-let [bar-speed 25
               stop-after (* bar-speed 120)
               phase     (r/atom 0)
               progress  (r/atom 0)
               timer     (js/setInterval
                          #(swap! phase (fn [p] (mod (inc p) (count pulse-colors))))
                          100)
               bar-timer (js/setInterval
                          #(swap! progress inc)
                          bar-speed)
               stopper   (js/setTimeout
                          #(do (js/clearInterval timer)
                               (js/clearInterval bar-timer)
                               (on-done))
                          stop-after)]
    (let [color  (nth pulse-colors @phase)
          filled (min bar-width (js/Math.floor (* @progress (/ bar-width 100))))]
      [:> ink/Box {:height rows :width cols :flexDirection "column" :justifyContent "center" :alignItems "center"}
       (into [:> ink/Box {:flexDirection "column"}]
             (map-indexed (fn [i line]
                            [:> ink/Text {:key i :color color} line])
                          big-lambda))
       [:> ink/Box {:marginTop 1}
        [:> ink/Text {:color color}
         (str "[" (apply str (repeat filled "█")) (apply str (repeat (- bar-width filled) "░")) "]")]]])
    (finally
      (js/clearInterval timer)
      (js/clearInterval bar-timer)
      (js/clearTimeout stopper)
      (on-done))))
